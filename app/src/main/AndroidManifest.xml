<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" >

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Permissão para Android 12L (API 32) e inferior para ler arquivos de mídia. -->
    <!-- Necessária se você não estiver usando o Seletor de Fotos em versões mais antigas. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" /> <!-- PERMISSÃO ADICIONADA: Para acesso seletivo a fotos no Android 14+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Project_gestoderisco" >
        <activity
            android:name=".MainActivity"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.App.Starting"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".view.RiskDetailActivity"
            android:exported="false" />
        <activity
            android:name=".view.SettingsActivity"
            android:exported="false"
            android:label="Configurações"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".view.OcorrenciasSalvasActivity"
            android:exported="false" />
        <activity
            android:name=".view.OcorrenciaDetailActivity"
            android:exported="false" />
        <activity
            android:name=".RegistroOcorrenciaActivity"
            android:exported="false"
            android:label="Registrar Ocorrência" />
    </application>

</manifest>
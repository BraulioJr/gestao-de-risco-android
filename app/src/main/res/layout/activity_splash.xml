    <?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_main"
        tools:context=".view.SplashActivity">

        <!-- Animação Distintiva de Carregamento (Radar)
             Usando Lottie para animações complexas e performáticas -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieRadar"
            android:layout_width="250dp"
            android:layout_height="250dp"
            app:lottie_rawRes="@raw/radar_animation"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logotipo do App (Sobreposto à Animação) -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_logo_monochromatic"
            app:layout_constraintBottom_toBottomOf="@+id/lottieRadar"
            app:layout_constraintEnd_toEndOf="@+id/lottieRadar"
            app:layout_constraintStart_toStartOf="@+id/lottieRadar"
            app:layout_constraintTop_toTopOf="@+id/lottieRadar" />

        <!-- Slogan/Status da Marca -->
        <TextView
            android:id="@+id/tvSlogan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:text="@string/about_slogan"
            android:textAllCaps="true"
            android:textColor="@color/primary_blue"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    
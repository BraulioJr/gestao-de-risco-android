<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema do aplicativo para o modo escuro. -->
    <!-- Herdar de Theme.Material3 também para o modo noturno. -->
    <!-- As cores dinâmicas serão aplicadas aqui também em Android 12+. -->
    <style name="Theme.Project_gestoderisco" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Cores Primárias (Fallback para modo escuro) -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorOnPrimary">@color/purple_700</item>
        <item name="colorPrimaryContainer">@color/purple_700</item>
        <item name="colorOnPrimaryContainer">@color/purple_200</item>

        <!-- Cores Secundárias (Fallback para modo escuro) -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/teal_700</item>
        <item name="colorOnSecondaryContainer">@color/white</item>
    </style>

    <!-- Sobrescreve o tema da Splash Screen para o modo noturno -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Cor de fundo escura para a Splash Screen -->
        <item name="windowSplashScreenBackground">@color/dark_grey</item>
        <!-- O ícone e o tema pós-splash permanecem os mesmos -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo_animated</item>
        <item name="postSplashScreenTheme">@style/Theme.Project_gestoderisco</item>
    </style>
</resources>
<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema base do aplicativo. -->
    <!-- Herdar de Theme.Material3 habilita o suporte a cores dinâmicas (Material You) no Android 12+ -->
    <!-- As cores definidas abaixo servirão de fallback para versões mais antigas do Android. -->
    <style name="Theme.Project_gestoderisco" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Cores Primárias -->
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorOnPrimary">@color/md_theme_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_onPrimaryContainer</item>

        <!-- Cores Secundárias -->
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_onSecondaryContainer</item>

        <!-- Outras cores do tema -->
        <item name="android:colorBackground">@color/md_theme_background</item>
        <item name="colorSurface">@color/md_theme_surface</item>
        <item name="colorOnSurface">@color/md_theme_onSurface</item>

        <!-- Atributos de Cores Customizadas -->
        <item name="riskLevelHighColor">@color/risk_level_high</item>
        <item name="riskLevelMediumColor">@color/risk_level_medium</item>
        <item name="riskLevelLowColor">@color/risk_level_low</item>
        <!-- Habilitar Tela Cheia (Ocultar barra de status) -->
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Tema para a Splash Screen moderna -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Cor de fundo da Splash Screen -->
        <item name="windowSplashScreenBackground">@color/white</item>
        <!-- Ícone a ser exibido (o drawable que criamos) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo_animated</item>
        <!-- Tema a ser aplicado após a Splash Screen -->
        <item name="postSplashScreenTheme">@style/Theme.Project_gestoderisco</item>
    </style>

</resources>

<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema base do aplicativo. -->
    <!-- Herdar de Theme.Material3 habilita o suporte a cores dinâmicas (Material You) no Android 12+ -->
    <!-- As cores definidas abaixo servirão de fallback para versões mais antigas do Android. -->
    <style name="Theme.Project_gestoderisco" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Cores Primárias (Fallback) -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/purple_200</item>
        <item name="colorOnPrimaryContainer">@color/purple_700</item>

        <!-- Cores Secundárias (Fallback) -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/teal_700</item>
        <item name="colorOnSecondaryContainer">@color/white</item>
    </style>

    <!-- Tema para a Splash Screen moderna -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Cor de fundo da Splash Screen -->
        <item name="windowSplashScreenBackground">@color/white</item>
        <!-- Ícone a ser exibido (o drawable que criamos) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo_animated</item>
        <!-- Tema a ser aplicado após a Splash Screen -->
        <item name="postSplashScreenTheme">@style/Theme.Project_gestoderisco</item>
    </style>

</resources>

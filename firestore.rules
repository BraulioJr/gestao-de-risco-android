rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que um usuário acesse apenas sua própria subcoleção de riscos.
    // A estrutura de dados esperada é: /users/{userId}/risks/{riskId}
    match /users/{userId}/risks/{riskId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}